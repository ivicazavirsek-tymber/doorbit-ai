### Environment
# APP_ENV treba da bude "dev" ili "prod"
APP_ENV=dev

# Obavezno za auth u browseru (kopiraj iz Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase → Authentication → URL Configuration: Redirect URLs moraju uključiti
# `${NEXT_PUBLIC_APP_URL}/auth/callback` (i putanju za reset lozinke ako koristiš query `next=`, npr. `/auth/callback?next=/reset-password`).

### Supabase (DEV)
SUPABASE_URL_DEV=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_DEV=

### Supabase (PROD)
SUPABASE_URL_PROD=
SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# Javni URL aplikacije (redirect posle Stripe checkout / portal). Lokalno: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

### Stripe (DEV)
STRIPE_SECRET_KEY_DEV=
STRIPE_WEBHOOK_SECRET_DEV=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_DEV=

# ID-jevi Stripe price-ova (Products → Price ID) za pretplate
STRIPE_PRICE_STARTER_MONTHLY_ID_DEV=
STRIPE_PRICE_PRO_MONTHLY_ID_DEV=
STRIPE_PRICE_STARTER_YEARLY_ID_DEV=
STRIPE_PRICE_PRO_YEARLY_ID_DEV=

# Opciono: priliv tokena po naplati (podrazumevano u kodu ako izostaviš)
# STRIPE_TOKENS_STARTER_MONTHLY=1000
# STRIPE_TOKENS_PRO_MONTHLY=3000
# STRIPE_TOKENS_STARTER_YEARLY=12000
# STRIPE_TOKENS_PRO_YEARLY=36000

### Stripe (PROD)
STRIPE_SECRET_KEY_PROD=
STRIPE_WEBHOOK_SECRET_PROD=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_PROD=

STRIPE_PRICE_STARTER_MONTHLY_ID_PROD=
STRIPE_PRICE_PRO_MONTHLY_ID_PROD=
STRIPE_PRICE_STARTER_YEARLY_ID_PROD=
STRIPE_PRICE_PRO_YEARLY_ID_PROD=

### AI (DEV)
OPENAI_API_KEY_DEV=
OPENAI_TEXT_MODEL=gpt-5.2

# Google AI (Gemini) — generisanje SLIKA ide isključivo preko servera (ovo nije NEXT_PUBLIC).
# Ključ: https://aistudio.google.com/apikey  (ili Google Cloud → APIs → credentials)
# Ako API vrati "API key expired" / API_KEY_INVALID, obnovi ključ na linku iznad i zameni vrednost ovde.
# Za APP_ENV=dev koristi GEMINI_API_KEY_DEV ili fallback GEMINI_API_KEY.
GEMINI_API_KEY_DEV=
# Opciono: GEMINI_API_KEY=... ako ne koristiš *_DEV ime
# GEMINI_API_KEY=

# Model koji podržava izlaz slike (responseModalities IMAGE). Podrazumevano u kodu: gemini-2.5-flash-image.
# Za novije preview modele (npr. gemini-3-pro-image-preview) kod automatski koristi API v1alpha.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

### AI (PROD)
OPENAI_API_KEY_PROD=
GEMINI_API_KEY_PROD=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

### Upload limits (bytes)
MAX_UPLOAD_BYTES=10485760
